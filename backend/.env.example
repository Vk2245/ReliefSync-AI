# ReliefSync-AI Environment Variables Template
# Copy this to .env and fill in your actual values

# ══════════════════════════════════════════════════════════════
# 📱 APPLICATION CONFIGURATION
# ══════════════════════════════════════════════════════════════
APP_NAME=ReliefSync-AI
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production
API_PREFIX=/api/v1

# ══════════════════════════════════════════════════════════════
# 🗄️ SUPABASE DATABASE
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ══════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ══════════════════════════════════════════════════════════════
# 🤖 GOOGLE GEMINI AI
# Get from: https://aistudio.google.com/app/apikey
# ══════════════════════════════════════════════════════════════
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════════════
# 🗺️ GOOGLE MAPS API
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Directions API
# ══════════════════════════════════════════════════════════════
GOOGLE_MAPS_API_KEY=AIzaSy...

# ══════════════════════════════════════════════════════════════
# 🔐 SECURITY & AUTHENTICATION
# Generate JWT secret: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════
JWT_SECRET_KEY=your-super-secret-64-character-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ══════════════════════════════════════════════════════════════
# 🚦 RATE LIMITING
# ══════════════════════════════════════════════════════════════
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ══════════════════════════════════════════════════════════════
# 🌐 CORS CONFIGURATION
# Update with your frontend URL after deployment
# ══════════════════════════════════════════════════════════════
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://reliefsyncai.vercel.app"]

# ══════════════════════════════════════════════════════════════
# 📝 NOTES
# ══════════════════════════════════════════════════════════════
# - NEVER commit .env file to Git
# - Keep SUPABASE_SERVICE_KEY secret (server-side only)
# - Use strong JWT_SECRET_KEY in production
# - Update CORS_ORIGINS with your actual frontend domain
# ══════════════════════════════════════════════════════════════
